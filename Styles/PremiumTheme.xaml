<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 🟣 PALETA NEON PURPLE -->
    <Color x:Key="BgDark">#05050E</Color>
    <Color x:Key="BgMain">#0A0018</Color>
    <Color x:Key="BgCard">#1A0038</Color>
    <Color x:Key="BgCardGlass">#240048</Color>
    <Color x:Key="Accent">#B026FF</Color>
    <Color x:Key="AccentLight">#D455FF</Color>
    <Color x:Key="AccentMagenta">#FF00FF</Color>
    <Color x:Key="AccentCyan">#00E5FF</Color>
    <Color x:Key="AccentGreen">#00E676</Color>
    <Color x:Key="AccentCombat">#FF0080</Color>
    <Color x:Key="AccentVisual">#00E5FF</Color>
    <Color x:Key="AccentSystem">#B026FF</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#D0D0F0</Color>
    <Color x:Key="TextMuted">#8080B0</Color>
    <Color x:Key="Border">#3A0078</Color>
    <Color x:Key="BorderGlass">rgba(180,100,255,0.12)</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgMainBrush" Color="{StaticResource BgMain}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLight}"/>
    <SolidColorBrush x:Key="AccentMagentaBrush" Color="{StaticResource AccentMagenta}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyan}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentCombatBrush" Color="{StaticResource AccentCombat}"/>
    <SolidColorBrush x:Key="AccentVisualBrush" Color="{StaticResource AccentVisual}"/>
    <SolidColorBrush x:Key="AccentSystemBrush" Color="{StaticResource AccentSystem}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>

    <!-- Gradientes Neon -->
    <LinearGradientBrush x:Key="BgMainGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A0018" Offset="0"/>
        <GradientStop Color="#05050E" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A0038" Offset="0"/>
        <GradientStop Color="#140028" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardActiveGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2A0050" Offset="0"/>
        <GradientStop Color="#1A0038" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#B026FF" Offset="0"/>
        <GradientStop Color="#FF00FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CombatGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0080" Offset="0"/>
        <GradientStop Color="#D400FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="VisualGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00E5FF" Offset="0"/>
        <GradientStop Color="#0088FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SystemGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B026FF" Offset="0"/>
        <GradientStop Color="#6600CC" Offset="1"/>
    </LinearGradientBrush>

    <!-- Efeitos -->
    <DropShadowEffect x:Key="CardShadow" ShadowDepth="4" BlurRadius="12" Opacity="0.4" Color="#1A0038"/>
    <DropShadowEffect x:Key="GlowEffect" ShadowDepth="0" BlurRadius="50" Opacity="0.4" Color="#B026FF"/>
    <DropShadowEffect x:Key="GlowCombat" ShadowDepth="0" BlurRadius="16" Opacity="0.5" Color="#FF0080"/>
    <DropShadowEffect x:Key="GlowVisual" ShadowDepth="0" BlurRadius="16" Opacity="0.5" Color="#00E5FF"/>
    <DropShadowEffect x:Key="GlowSystem" ShadowDepth="0" BlurRadius="16" Opacity="0.5" Color="#B026FF"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgMainGradient}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Search Box Neon -->
    <Style x:Key="GlassBox" TargetType="TextBox">
        <Setter Property="Background" Value="#1A0038"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#3A0078"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="36,8,12,8"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <TextBlock Text="🔍  Buscar funções..." FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Collapsed" x:Name="Placeholder"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       IsHitTestVisible="False"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,0,0,0"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botões com gradiente neon -->
    <Style x:Key="BaseButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7" Effect="{StaticResource CardShadow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="TitleBarBtn" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="24"/>
    </Style>

    <!-- Toggle Switch Neon Purple -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Bg" Width="46" Height="26"
                            Background="#2A0048"
                            BorderBrush="#3A0078" BorderThickness="1"
                            CornerRadius="13"
                            Effect="{StaticResource CardShadow}">
                        <Ellipse x:Name="Thumb" Width="20" Height="20"
                                 Fill="#606090"
                                 HorizontalAlignment="Left" Margin="2,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bg"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#B026FF" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="Thumb"
                                                        Storyboard.TargetProperty="Fill.Color"
                                                        To="#FFFFFF" Duration="0:0:0.2"/>
                                        <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="23,0,0,0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bg"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#2A0048" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="Thumb"
                                                        Storyboard.TargetProperty="Fill.Color"
                                                        To="#606090" Duration="0:0:0.2"/>
                                        <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="2,0,0,0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title Bar Button -->
    <Style x:Key="TitleBarButton" TargetType="Button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BorderRoot" Background="Transparent" CornerRadius="5">
                        <TextBlock Text="✕" FontSize="12" Foreground="#8080B0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BorderRoot" Property="Background" Value="#FF3366"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Scrollbar Neon -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="Transparent"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Background="Transparent"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border x:Name="ThumbBg" Background="#B026FF" CornerRadius="6"
                                                    Margin="2,0"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBg" Property="Background" Value="#D455FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <ScrollContentPresenter CanContentScroll="True"
                                                 Margin="{TemplateBinding Padding}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Stretch"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
