<Window x:Class="PointBlankPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PointBlankPanel.ViewModels"
        x:Name="root"
        Title="System Service Host v1.0" Height="780" Width="850"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <DataTemplate x:Key="ItemCard">
            <Border CornerRadius="10" Effect="{StaticResource CardShadow}"
                    Margin="0,0,0,10" Opacity="0">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetName="SlideUp" Storyboard.TargetProperty="Y" From="15" To="0" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform x:Name="SlideUp" Y="15"/>
                        <ScaleTransform CenterX="0.5" CenterY="0.5"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[1].ScaleX" To="1.015" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[1].ScaleY" To="1.015" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[1].ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[1].ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Border x:Name="AccentBar" HorizontalAlignment="Left" Width="5"
                            CornerRadius="10,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource SystemGradient}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Category}" Value="PLAYER">
                                        <Setter Property="Background" Value="{StaticResource CombatGradient}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="VISUAL">
                                        <Setter Property="Background" Value="{StaticResource VisualGradient}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="BOOSTER">
                                        <Setter Property="Background" Value="{StaticResource AccentCyanBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Border x:Name="CardBody" Margin="5,0,0,0"
                            Background="{StaticResource CardGradient}"
                            BorderBrush="#3A0078"
                            BorderThickness="1" CornerRadius="10"
                            Padding="14,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CardActiveGradient}"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsActive}" Value="True"/>
                                            <Condition Binding="{Binding Category}" Value="PLAYER"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCombatBrush}"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsActive}" Value="True"/>
                                            <Condition Binding="{Binding Category}" Value="VISUAL"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentVisualBrush}"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsActive}" Value="True"/>
                                            <Condition Binding="{Binding Category}" Value="BOOSTER"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsActive}" Value="True"/>
                                            <Condition Binding="{Binding Category}" Value="SISTEMAS"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentSystemBrush}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Column="0" Grid.RowSpan="2" Width="40" Height="40"
                                    CornerRadius="10" Margin="0,0,14,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SystemGradient}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Category}" Value="PLAYER">
                                                <Setter Property="Background" Value="{StaticResource CombatGradient}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Category}" Value="VISUAL">
                                                <Setter Property="Background" Value="{StaticResource VisualGradient}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Category}" Value="BOOSTER">
                                                <Setter Property="Background" Value="{StaticResource AccentCyanBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Icon}" FontSize="18"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="9" FontWeight="Bold"
                                               Margin="10,0,0,1" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="10.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- Keyboard speed/delay controls (visible only for Teclado Mais Rápido) -->
                            <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                        Orientation="Horizontal" Margin="0,6,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Name}" Value="Teclado Mais Rápido">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Speed:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <Slider Minimum="0" Maximum="31" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Width="100" Margin="4,0" Value="{Binding DataContext.KeyboardSpeed, ElementName=root}"
                                        Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="{Binding DataContext.KeyboardSpeed, ElementName=root}"
                                           FontSize="10" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Width="20"/>
                                <TextBlock Text="Delay:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                                <Slider Minimum="0" Maximum="3" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Width="70" Margin="4,0" Value="{Binding DataContext.KeyboardDelay, ElementName=root}"
                                        Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="{Binding DataContext.KeyboardDelay, ElementName=root}"
                                           FontSize="10" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Width="16"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Grid.Row="0"
                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      Style="{StaticResource ToggleSwitch}"
                                      Command="{Binding ElementName=root, Path=DataContext.ToggleCommand}"
                                      CommandParameter="{Binding}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <ColorAnimation Storyboard.TargetName="Grad1"
                                    Storyboard.TargetProperty="Color"
                                    From="#0A0018" To="#150030" Duration="0:0:5"/>
                    <ColorAnimation Storyboard.TargetName="Grad2"
                                    Storyboard.TargetProperty="Color"
                                    From="#05050E" To="#0E0018" Duration="0:0:5"/>
                    <DoubleAnimation Storyboard.TargetName="N1Pos"
                                     Storyboard.TargetProperty="X"
                                     From="-80" To="80" Duration="0:0:12"/>
                    <DoubleAnimation Storyboard.TargetName="N1Pos"
                                     Storyboard.TargetProperty="Y"
                                     From="-40" To="40" Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="Nebula1"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.07" To="0.13" Duration="0:0:6"/>
                    <DoubleAnimation Storyboard.TargetName="N2Pos"
                                     Storyboard.TargetProperty="X"
                                     From="60" To="-60" Duration="0:0:14"/>
                    <DoubleAnimation Storyboard.TargetName="N2Pos"
                                     Storyboard.TargetProperty="Y"
                                     From="-60" To="60" Duration="0:0:11"/>
                    <DoubleAnimation Storyboard.TargetName="Nebula2"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.05" To="0.1" Duration="0:0:7"/>
                    <DoubleAnimation Storyboard.TargetName="N3Pos"
                                     Storyboard.TargetProperty="X"
                                     From="-40" To="100" Duration="0:0:16"/>
                    <DoubleAnimation Storyboard.TargetName="N3Pos"
                                     Storyboard.TargetProperty="Y"
                                     From="50" To="-30" Duration="0:0:9"/>
                    <DoubleAnimation Storyboard.TargetName="Nebula3"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.04" To="0.08" Duration="0:0:8"/>
                    <DoubleAnimation Storyboard.TargetName="N4Pos"
                                     Storyboard.TargetProperty="X"
                                     From="80" To="-80" Duration="0:0:13"/>
                    <DoubleAnimation Storyboard.TargetName="N4Pos"
                                     Storyboard.TargetProperty="Y"
                                     From="30" To="-50" Duration="0:0:15"/>
                    <DoubleAnimation Storyboard.TargetName="Nebula4"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.04" To="0.09" Duration="0:0:5.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Margin="8" CornerRadius="12"
            BorderBrush="#B026FF60" BorderThickness="1"
            Effect="{StaticResource GlowEffect}"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop x:Name="Grad1" Color="#0A0018" Offset="0"/>
                <GradientStop x:Name="Grad2" Color="#05050E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Canvas IsHitTestVisible="False">
                <Ellipse x:Name="Nebula1" Width="500" Height="350"
                         Fill="#B026FF" Opacity="0.1"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="N1Pos"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="Nebula2" Width="400" Height="450"
                         Fill="#FF00FF" Opacity="0.07"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="N2Pos"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="Nebula3" Width="450" Height="350"
                         Fill="#00E5FF" Opacity="0.05"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect><BlurEffect Radius="110"/></Ellipse.Effect>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="N3Pos"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="Nebula4" Width="300" Height="400"
                         Fill="#FF0080" Opacity="0.06"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect><BlurEffect Radius="130"/></Ellipse.Effect>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="N4Pos"/></Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══ TITLE BAR ═══ -->
                <Border Grid.Row="0" Height="36" Background="#0A0018"
                        MouseDown="TitleBar_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0">
                            <Border Width="22" Height="22" CornerRadius="6"
                                    Background="{StaticResource AccentGradient}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⚡" FontSize="11" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="System Service Host" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Button Content="✕" Style="{StaticResource TitleBarButton}" Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ MAIN: SIDEBAR + CONTENT ═══ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ///// SIDEBAR ///// -->
                    <Border Grid.Column="0" Background="#080012" Margin="0,0,0,0"
                            BorderBrush="#3A0078" BorderThickness="0,0,1,0">
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="6,12,6,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel VerticalAlignment="Top"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Height="62"
                                            CornerRadius="8" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#2A0050"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1A0038"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding ElementName=root, Path=DataContext.SelectCategoryCommand}"
                                                          CommandParameter="{Binding Label}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Icon}" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Label}" FontSize="8.5"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" Margin="0,1,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentLightBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- ///// RIGHT CONTENT ///// -->
                    <Grid Grid.Column="1" Margin="0,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Cabeçalho da categoria -->
                        <Border Grid.Row="0" Padding="18,14,18,10"
                                BorderBrush="#3A0078" BorderThickness="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedCategory}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="10.5"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="🔗 Conectar" Command="{Binding ConnectCommand}"
                                            Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="10.5"/>
                                    <Button Content="✔ Todas" Command="{Binding EnableAllCommand}"
                                            Style="{StaticResource BaseButton}" Padding="12,6" FontSize="10.5" Margin="6,0,0,0"/>
                                    <Button Content="✘ Todas" Command="{Binding DisableAllCommand}"
                                            Style="{StaticResource BaseButton}" Padding="12,6" FontSize="10.5" Margin="6,0,0,0"/>
                                    <Border Width="1" Background="#3A0078" Margin="6,2,6,2"/>
                                    <Button Content="▲" Style="{StaticResource TitleBarBtn}" Padding="4,2" FontSize="11"
                                            Click="ScrollUp_Click" Margin="0,0,2,0"/>
                                    <Button Content="▼" Style="{StaticResource TitleBarBtn}" Padding="4,2" FontSize="11"
                                            Click="ScrollDown_Click"/>
                                    <Button Content="📋" Style="{StaticResource TitleBarBtn}" Padding="4,2" FontSize="11"
                                            Command="{Binding ToggleLogCommand}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Search -->
                        <Border Grid.Row="1" Padding="18,2,18,6">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource GlassBox}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button Content="⚡ Otimizar Tudo" Command="{Binding OtimizarTudoCommand}"
                                                Style="{StaticResource BaseButton}" Padding="10,4" FontSize="10"/>
                                        <Button Content="↩ Restaurar" Command="{Binding RestaurarPadroesCommand}"
                                                Style="{StaticResource BaseButton}" Padding="10,4" FontSize="10" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <!-- RAM info banner -->
                                <Border Background="#1A0038" BorderBrush="#3A0078" BorderThickness="1" CornerRadius="8"
                                        Padding="10,6" Margin="0,6,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="MEMÓRIA">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding RamInfo}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentCyanBrush}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Dashboard banner -->
                                <Border Background="#1A0038" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="8"
                                        Padding="10,6" Margin="0,6,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="UTILITÁRIOS">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding DashboardInfo}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentCyanBrush}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Items -->
                        <Grid Grid.Row="2">
                            <ScrollViewer Padding="12,0,12,6" x:Name="ItemScroller"
                                          VerticalScrollBarVisibility="Visible"
                                          Background="Transparent">
                                <Grid>
                                    <!-- Single column (default) -->
                                    <ItemsControl ItemsSource="{Binding CurrentItems}"
                                                  ItemTemplate="{StaticResource ItemCard}"
                                                  Visibility="Visible">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="ItemsPanel">
                                                    <Setter.Value>
                                                        <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="SISTEMAS">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <!-- 2-column grid (only for SISTEMAS) -->
                                    <ItemsControl ItemsSource="{Binding CurrentItems}"
                                                  ItemTemplate="{StaticResource ItemCard}"
                                                  Visibility="Collapsed">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="SISTEMAS">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemWidth="290"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>
                            <!-- Theme selector overlay (bottom of items area, only for CONFIG) -->
                            <Border VerticalAlignment="Bottom" CornerRadius="10" Effect="{StaticResource CardShadow}"
                                    Margin="12,0,12,6" Padding="14,10" Background="{StaticResource CardGradient}"
                                    BorderBrush="#3A0078" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedCategory}" Value="CONFIG">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="🎨  Tema Customizável" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Themes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="40" Height="40" CornerRadius="20" Cursor="Hand"
                                                        Margin="4,0" BorderThickness="2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{Binding AccentBrush}"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                                      Command="{Binding ElementName=root, Path=DataContext.SelectAccentCommand}"
                                                                      CommandParameter="{Binding Name}"/>
                                                    </Border.InputBindings>
                                                    <TextBlock Text="{Binding Name}" FontSize="8" FontWeight="Bold"
                                                               Foreground="White" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" TextWrapping="Wrap"
                                                               TextAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="🔄 Verificar Atualizações" Command="{Binding CheckUpdateCommand}"
                                            Style="{StaticResource BaseButton}" Padding="10,4" FontSize="10"
                                            HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Action Log overlay -->
                            <Border VerticalAlignment="Bottom" CornerRadius="10" Effect="{StaticResource CardShadow}"
                                    Margin="12,0,12,6" Padding="14,10" Background="{StaticResource CardGradient}"
                                    BorderBrush="#3A0078" BorderThickness="1" MaxHeight="160">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowLog}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ActionLog}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="Consolas" Margin="0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Status Bar -->
                <Border Grid.Row="2" Height="26" Background="#0A0018"
                        BorderBrush="#3A0078" BorderThickness="0,1,0,0"
                        Padding="16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                                   FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
